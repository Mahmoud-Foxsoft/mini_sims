{
  "info": {
    "name": "QuickSMS External API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://your-domain.com/api/v1"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Get Profile",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/me"
      }
    },
    {
      "name": "List Orders",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/orders?filters[created_at]=2026-04-01",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "orders"
          ],
          "query": [
            {
              "key": "filters[created_at]",
              "value": "2026-04-01"
            }
          ]
        }
      }
    },
    {
      "name": "List Phone Numbers",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/phone-numbers?filters[service_name]=telegram&filters[status]=pending&filters[phone_number]=+1555",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "phone-numbers"
          ],
          "query": [
            {
              "key": "filters[service_name]",
              "value": "telegram"
            },
            {
              "key": "filters[status]",
              "value": "pending"
            },
            {
              "key": "filters[phone_number]",
              "value": "+1555"
            }
          ]
        }
      }
    },
    {
      "name": "List Transactions",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/transactions?per_page=20&filters[type]=credit&filters[source]=payment&filters[reference]=abc",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "transactions"
          ],
          "query": [
            {
              "key": "per_page",
              "value": "20"
            },
            {
              "key": "filters[type]",
              "value": "credit"
            },
            {
              "key": "filters[source]",
              "value": "payment"
            },
            {
              "key": "filters[reference]",
              "value": "abc"
            }
          ]
        }
      }
    },
    {
      "name": "List Payments",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/payments?filters[status]=finished&filters[created_date]=2026-04-01",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "payments"
          ],
          "query": [
            {
              "key": "filters[status]",
              "value": "finished"
            },
            {
              "key": "filters[created_date]",
              "value": "2026-04-01"
            }
          ]
        }
      }
    },
    {
      "name": "Create Payment",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 50,\n  \"currency\": \"USD\",\n  \"paid_amount\": 50\n}"
        },
        "url": "{{base_url}}/payments"
      }
    },
    {
      "name": "Get Payment Currencies",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{base_url}}/payments/currencies"
      }
    },
    {
      "name": "Estimate Payment",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 50,\n  \"currency\": \"USD\"\n}"
        },
        "url": "{{base_url}}/payments/estimate"
      }
    }
  ]
}
